# VenueFlow - Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://venueflow:venueflow_dev@localhost:5432/venueflow
DATABASE_POOL_SIZE=20
DATABASE_IDLE_TIMEOUT=30000

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================================================
# KAFKA
# ============================================================================
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=venueflow-services
KAFKA_TIMEOUT_MS=10000

# ============================================================================
# AUTHENTICATION & JWT
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Weather API
WEATHER_API_KEY=
WEATHER_API_ENDPOINT=https://api.weather.com/v1

# Traffic API
TRAFFIC_API_KEY=
TRAFFIC_API_ENDPOINT=https://api.traffic.com/v1

# ============================================================================
# VENUE CONFIGURATION
# ============================================================================
VENUE_IDS=venue-1,venue-2,venue-3
DEFAULT_VENUE_ID=venue-1

# ============================================================================
# FEATURES & FLAGS
# ============================================================================
ENABLE_SIMULATION=true
ENABLE_DEBUG_LOGGING=false
ENABLE_METRICS=true
MAX_CONCURRENT_EVENTS=100

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# SERVICE PORTS (Local Development)
# ============================================================================
AUTH_SERVICE_PORT=3001
ENTRY_ROUTER_PORT=3002
NOTIFICATION_SERVICE_PORT=3003
WAYFINDING_ENGINE_PORT=3004
VENDOR_INTELLIGENCE_PORT=3006
STAFF_MANAGEMENT_PORT=3007
EMERGENCY_COORDINATOR_PORT=3008
REWARDS_SERVICE_PORT=3009
EXTERNAL_INTEGRATION_PORT=3011
INCIDENT_SERVICE_PORT=3012
COMPLIANCE_SERVICE_PORT=3013
KIOSK_SERVICE_PORT=3014
EVENT_SERVICE_PORT=3015

# ============================================================================
# WEBSOCKET
# ============================================================================
WS_PORT=3010
WS_URL=ws://localhost:3010

# ============================================================================
# SECURITY
# ============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SESSION_SECRET=your-session-secret
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# PRODUCTION OVERRIDES
# ============================================================================
NODE_ENV=development
# Set to 'production' when deploying to production
