# Auth Service — environment variables
# Copy to .env and fill in values before running.

# PostgreSQL connection string
DATABASE_URL=postgres://venueflow:password@localhost:5432/venueflow

# RS256 key pair (PEM, newlines escaped as \n)
# Leave unset in development — an ephemeral key pair will be generated at startup.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Server port (default: 3001)
PORT=3001
