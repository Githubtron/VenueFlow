{
  "name": "@venueflow/staff-management",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "ts-node src/index.ts",
    "build": "tsc",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@venueflow/shared-types": "*",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.2",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "moduleNameMapper": {
      "^@venueflow/shared-types$": "<rootDir>/../../packages/shared-types/src/index.ts"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "diagnostics": false }]
    }
  }
}
