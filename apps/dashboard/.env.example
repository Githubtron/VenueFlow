# VenueFlow Operations Dashboard - Environment Variables

# API Configuration - Set this to your API server URL (e.g., https://api.yourdomain.com)
VITE_API_URL=http://localhost:3001

# Optional: WebSocket server URL for real-time updates
VITE_WS_URL=ws://localhost:3010

# Optional: Analytics or monitoring
VITE_SENTRY_DSN=

# Optional: Feature flags
VITE_ENABLE_SIMULATION=true
VITE_ENABLE_DEBUG=false
